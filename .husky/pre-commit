#!/bin/sh
# Pre-commit hook for Frontend Performance Profiler
# Uses pnpm for package management

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo "${BLUE}╔════════════════════════════════════════════════════════════╗${NC}"
echo "${BLUE}║     Frontend Performance Profiler - Pre-commit Checks     ║${NC}"
echo "${BLUE}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Check if pnpm is installed
if ! command -v pnpm &> /dev/null; then
    echo "${RED}✗ pnpm is not installed. Please install pnpm first.${NC}"
    exit 1
fi

# Get list of staged files for targeted checks
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo "${GREEN}✓ No TypeScript files staged, skipping checks${NC}"
    exit 0
fi

echo "${YELLOW}▶ Running pre-commit quality checks...${NC}"
echo ""

# 1. TypeScript Type Checking
echo "${YELLOW}1/6 Checking TypeScript types...${NC}"
if ! pnpm exec tsc --noEmit; then
    echo "${RED}✗ TypeScript type checking failed${NC}"
    echo "${RED}Please fix type errors before committing${NC}"
    exit 1
fi
echo "${GREEN}✓ TypeScript types valid${NC}"
echo ""

# 2. ESLint on Staged Files
echo "${YELLOW}2/6 Running ESLint on staged files...${NC}"
if ! pnpm exec lint-staged; then
    echo "${RED}✗ ESLint checks failed${NC}"
    echo "${RED}Please fix linting errors before committing${NC}"
    exit 1
fi
echo "${GREEN}✓ ESLint checks passed${NC}"
echo ""

# 3. Unit Tests (affected by changes)
echo "${YELLOW}3/6 Running unit tests...${NC}"
echo "${YELLOW}   (Running tests related to staged files)${NC}"
if ! pnpm test -- --run --silent; then
    echo "${RED}✗ Unit tests failed${NC}"
    echo "${RED}Please fix failing tests before committing${NC}"
    exit 1
fi
echo "${GREEN}✓ All unit tests passed${NC}"
echo ""

# 4. Check for console.log statements
echo "${YELLOW}4/6 Checking for console.log statements...${NC}"
CONSOLE_LOGS=$(grep -r "console\.\(log\|warn\|debug\|info\|trace\)" src --include="*.ts" --include="*.tsx" 2>/dev/null | \
    grep -v "playgroundStore.ts" | \
    grep -v "ci-cd/index.ts" | \
    grep -v "analyzer.ts" | \
    grep -v "transformer.ts" | \
    grep -v "errorHandler.ts" | \
    grep -v "test" | \
    grep -v "__tests__" | \
    wc -l | tr -d ' ')

if [ "$CONSOLE_LOGS" -gt 0 ]; then
    echo "${RED}✗ Found console.log/warn/debug/info/trace statements:${NC}"
    grep -rn "console\.\(log\|warn\|debug\|info\|trace\)" src --include="*.ts" --include="*.tsx" 2>/dev/null | \
        grep -v "playgroundStore.ts" | \
        grep -v "ci-cd/index.ts" | \
        grep -v "analyzer.ts" | \
        grep -v "transformer.ts" | \
        grep -v "errorHandler.ts" | \
        grep -v "test" | \
        grep -v "__tests__"
    echo ""
    echo "${YELLOW}Use the logger utility or allowlist specific files${NC}"
    exit 1
fi
echo "${GREEN}✓ No unwanted console statements found${NC}"
echo ""

# 5. Check for TODO/FIXME in production code
echo "${YELLOW}5/6 Checking for TODO/FIXME comments...${NC}"
TODO_COUNT=$(grep -r "TODO\|FIXME" src --include="*.ts" --include="*.tsx" 2>/dev/null | \
    grep -v "__tests__" | \
    grep -v ".test." | \
    wc -l | tr -d ' ')

if [ "$TODO_COUNT" -gt 5 ]; then
    echo "${YELLOW}⚠ Found $TODO_COUNT TODO/FIXME comments in production code${NC}"
    echo "${YELLOW}Consider addressing these before committing${NC}"
    # Don't fail, just warn
else
    echo "${GREEN}✓ TODO/FIXME count acceptable ($TODO_COUNT)${NC}"
fi
echo ""

# 6. File size check
echo "${YELLOW}6/6 Checking file sizes...${NC}"
LARGE_FILES=$(find src -name "*.ts" -o -name "*.tsx" 2>/dev/null | while read file; do
    LINES=$(wc -l < "$file" | tr -d ' ')
    if [ "$LINES" -gt 500 ]; then
        echo "$file ($LINES lines)"
    fi
done)

if [ -n "$LARGE_FILES" ]; then
    echo "${YELLOW}⚠ Large files detected (consider refactoring):${NC}"
    echo "$LARGE_FILES"
    # Don't fail, just warn
else
    echo "${GREEN}✓ No oversized files${NC}"
fi
echo ""

# Success message
echo "${GREEN}╔════════════════════════════════════════════════════════════╗${NC}"
echo "${GREEN}║           ✓ All pre-commit checks passed!                  ║${NC}"
echo "${GREEN}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""
echo "${BLUE}Commit ready for submission${NC}"
exit 0
